{
  "description": "second-brain-capture: redact-at-source capture (PostToolUse), incremental instant-digest push per turn (Stop), and final flush + best-effort LLM upgrade (SessionEnd).",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash|Write|Edit|NotebookEdit|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/capture-event.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/session-flush.sh",
            "timeout": 60
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/session-flush.sh",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
